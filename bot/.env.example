# Server Configuration
BOT_PORT=4100
BOT_HOST=0.0.0.0
BOT_TIMEZONE=Africa/Lagos
ENABLE_SCHEDULER=false

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost/church_bot

# Queue (Redis)
REDIS_URL=redis://127.0.0.1:6379

# WhatsApp Provider (meta or stub)
WHATSAPP_PROVIDER=meta

# Meta WhatsApp Cloud API
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_PHONE_NUMBER_ID=123456789012345
META_WABA_ID=987654321098765
META_WEBHOOK_VERIFY_TOKEN=fgc-upperroom-webhook-2026
META_APP_SECRET=abcdef1234567890abcdef1234567890
META_API_VERSION=v21.0

# LLM Routing (auto, vertex, openai, gemini, none)
# auto order: vertex → openai → gemini → static templates
LLM_PROVIDER=auto

# Vertex AI Gemini (preferred in production — service account auth)
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
# VERTEX_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini direct API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Monitoring (optional)
ALERT_WEBHOOK_URL=https://your-monitoring-service.com/webhook
